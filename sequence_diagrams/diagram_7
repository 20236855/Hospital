// Sequence Diagram
digraph {
	rankdir=TB splines=ortho
	node [fillcolor=lightblue shape=box style="rounded,filled"]
	edge [fontname=Arial fontsize=10]
	node [fontname=Arial fontsize=10]
	Client [label="医生端" fillcolor="#E3F2FD" shape=box style="rounded,filled"]
	Gateway [label="Gateway网关" fillcolor="#E3F2FD" shape=box style="rounded,filled"]
	EMR [label="his-emr" fillcolor="#E3F2FD" shape=box style="rounded,filled"]
	Patient [label="his-patient" fillcolor="#E3F2FD" shape=box style="rounded,filled"]
