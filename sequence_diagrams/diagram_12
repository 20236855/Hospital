// Sequence Diagram
digraph {
	rankdir=TB splines=ortho
	node [fillcolor=lightblue shape=box style="rounded,filled"]
	edge [fontname=Arial fontsize=10]
	node [fontname=Arial fontsize=10]
	Client [label="患者端/收费员端" fillcolor="#E3F2FD" shape=box style="rounded,filled"]
	Gateway [label="Gateway网关" fillcolor="#E3F2FD" shape=box style="rounded,filled"]
	Register [label="his-register" fillcolor="#E3F2FD" shape=box style="rounded,filled"]
	Schedule [label="his-doctor" fillcolor="#E3F2FD" shape=box style="rounded,filled"]
	Payment [label="his-payment" fillcolor="#E3F2FD" shape=box style="rounded,filled"]
	DB [label=MySQL fillcolor="#E3F2FD" shape=box style="rounded,filled"]
	Client -> Gateway [label="PUT /register/cancel/{registerId}" penwidth=1 style=solid]
	Gateway -> Register [label="退号请求" penwidth=1 style=solid]
	Register -> DB [label="SELECT * FROM register WHERE registerId=?" penwidth=1 style=solid]
	"DB-" -> Register [label="返回挂号记录" penwidth=1 style=solid]
	condition_start [label="IF: 可退号(未就诊、未检查)" fillcolor="#FFF9C4" shape=diamond style=filled]
	Register -> Schedule [label="恢复号源" penwidth=1 style=solid]
	Schedule -> DB [label="UPDATE schedule SET reservedNumber=reservedNumber-..." penwidth=1 style=solid]
	Register -> Payment [label="发起退款" penwidth=1 style=solid]
	Payment -> DB [label="UPDATE payment SET payStatus=REFUND" penwidth=1 style=solid]
	Register -> DB [label="UPDATE register SET registerStatus=CANCELLED" penwidth=1 style=solid]
	"Register-" -> Gateway [label="退号成功" penwidth=1 style=solid]
	"Gateway-" -> Client [label="{\"status\": \"CANCELLED\"}" penwidth=1 style=solid]
	condition_else [label="ELSE: 不可退号" fillcolor="#FFECB3" shape=diamond style=filled]
	"Register-" -> Gateway [label="退号失败" penwidth=1 style=solid]
	"Gateway-" -> Client [label="{\"code\": 500}" penwidth=1 style=solid]
	condition_end [label=END fillcolor="#FFCDD2" shape=box style="rounded,filled"]
}
