<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.hisdoctor.mapper.RegistLevelMapper">
    
    <resultMap type="RegistLevel" id="RegistLevelResult">
        <result property="levelId"    column="level_id"    />
        <result property="levelName"    column="level_name"    />
        <result property="fee"    column="fee"    />
        <result property="sort"    column="sort"    />
        <result property="status"    column="status"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectRegistLevelVo">
        select level_id, level_name, fee, sort, status, create_time, update_time from regist_level
    </sql>

    <select id="selectRegistLevelList" parameterType="RegistLevel" resultMap="RegistLevelResult">
        <include refid="selectRegistLevelVo"/>
        <where>  
            <if test="levelName != null  and levelName != ''"> and level_name like concat('%', #{levelName}, '%')</if>
            <if test="fee != null "> and fee = #{fee}</if>
            <if test="sort != null "> and sort = #{sort}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
        </where>
    </select>
    
    <select id="selectRegistLevelByLevelId" parameterType="Long" resultMap="RegistLevelResult">
        <include refid="selectRegistLevelVo"/>
        where level_id = #{levelId}
    </select>

    <insert id="insertRegistLevel" parameterType="RegistLevel" useGeneratedKeys="true" keyProperty="levelId">
        insert into regist_level
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="levelName != null and levelName != ''">level_name,</if>
            <if test="fee != null">fee,</if>
            <if test="sort != null">sort,</if>
            <if test="status != null">status,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="levelName != null and levelName != ''">#{levelName},</if>
            <if test="fee != null">#{fee},</if>
            <if test="sort != null">#{sort},</if>
            <if test="status != null">#{status},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
         </trim>
    </insert>

    <update id="updateRegistLevel" parameterType="RegistLevel">
        update regist_level
        <trim prefix="SET" suffixOverrides=",">
            <if test="levelName != null and levelName != ''">level_name = #{levelName},</if>
            <if test="fee != null">fee = #{fee},</if>
            <if test="sort != null">sort = #{sort},</if>
            <if test="status != null">status = #{status},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where level_id = #{levelId}
    </update>

    <delete id="deleteRegistLevelByLevelId" parameterType="Long">
        delete from regist_level where level_id = #{levelId}
    </delete>

    <delete id="deleteRegistLevelByLevelIds" parameterType="String">
        delete from regist_level where level_id in 
        <foreach item="levelId" collection="array" open="(" separator="," close=")">
            #{levelId}
        </foreach>
    </delete>
</mapper>